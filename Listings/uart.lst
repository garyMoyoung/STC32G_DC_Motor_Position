  107          void UART2_SendByte(unsigned char dat)
  108          {
  109   1          /* 等待缓冲区有空位 */
  110   1          unsigned char next = (uart2_tx_head + 1) % UART2_BUF_SIZE;
  111   1          while (next == uart2_tx_tail);      // 缓冲区满则等待
  112   1      
