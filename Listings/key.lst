  191          /*=============================================================================
  192           * 单个按键状态机处理
  193           * 
  194           * 状态转移：
  195           *   0(释放) -> 1(按下) -> 判定为单击?(有),再判双击?(有) -> 0(释放)
  196           *                      -> 长按判定?(有)长按 -> 0(释放)
  197           *
  198           * 双击逻辑：
  199           *   第一次单击后，在300ms内再按一次即为双击
  200           *===========================================================================*/
  201          static void Key_ScanSingle(KEY_Struct *pkey, unsigned char pin)
  202          {
  203   1          pkey->pin_level = pin;
  204   1          
  205   1          // ========== 按键按下过程 ==========
  206   1          if (pkey->pin_level == 0)  // GPIO为0
  207   1          {
  208   2              if (pkey->state == 0)  // 从释放状态进入
  209   2              {
  210   3                  pkey->debounce_cnt++;
  211   3                  if (pkey->debounce_cnt >= KEY_DEBOUNCE_TIME)
  212   3                  {
  213   4                      pkey->state = 1;
  214   4                      pkey->press_time = 0;
  215   4                      pkey->debounce_cnt = 0;
  216   4                  }
  217   3              }
  218   2              else if (pkey->state == 1)
  219   2              {
  220   3                  pkey->press_time++;
  221   3                  
  222   3                  // 长按判定（1000ms）
  223   3                  if (pkey->press_time == KEY_LONG_PRESS_TIME)
  224   3                  {
  225   4                      pkey->event = KEY_LONG_PRESS;
  226   4                      pkey->click_count = 0;  // 清除单击计数，禁止后续双击识别
  227   4                      pkey->click_timer = 0;  // 停止双击定时器
  228   4                  }
  229   3                  // 长按持续中（每100ms）
  230   3                  else if (pkey->press_time > KEY_LONG_PRESS_TIME && 
  231   3                           pkey->press_time % 100 == 0)
  232   3                  {
  233   4                      pkey->event = KEY_PRESSING;
  234   4                  }
  235   3              }
  236   2          }
  237   1          
  238   1          // ========== 按键释放过程 ==========
  239   1          else  // GPIO为1（释放）
  240   1          {
  241   2              if (pkey->state == 1)
  242   2              {
  243   3                  pkey->debounce_cnt++;
  244   3                  if (pkey->debounce_cnt >= KEY_DEBOUNCE_TIME)
  245   3                  {
  246   4                      pkey->state = 0;
  247   4                      pkey->debounce_cnt = 0;
  248   4                      
  249   4                      // 判定是短按还是长按
  250   4                      if (pkey->press_time < KEY_LONG_PRESS_TIME)
  251   4                      {
  252   5                          // 短按逻辑
  253   5                          pkey->click_count++;
  254   5                          
  255   5                          if (pkey->click_count == 1)
  256   5                          {
C251 COMPILER V5.60.0,  key                                                                19/03/26  18:12:35  PAGE 5   

  257   6                              // 第一次单击：立即发送事件，启动双击检测
  258   6                              pkey->event = KEY_SINGLE_CLICK;
  259   6                              pkey->click_timer = KEY_DOUBLE_CLICK_INTERVAL;
  260   6                          }
  261   5                          else if (pkey->click_count >= 2)
  262   5                          {
  263   6                              // 第二次单击：立即发送双击事件，停止定时器
  264   6                              pkey->event = KEY_DOUBLE_CLICK;
  265   6                              pkey->click_timer = 0;  // 关键：停止定时器，防止后续的单击重复
  266   6                              pkey->click_count = 0;
  267   6                          }
  268   5                      }
  269   4                      else
  270   4                      {
  271   5                          // 长按释放
  272   5                          pkey->event = KEY_RELEASE;
  273   5                          pkey->click_count = 0;
  274   5                          pkey->click_timer = 0;
  275   5                      }
  276   4                  }
  277   3              }
  278   2              else
  279   2              {
  280   3                  pkey->debounce_cnt = 0;
  281   3              }
  282   2          }
  283   1          
  284   1          // ========== 双击定时器倒计时 ==========
  285   1          if (pkey->click_timer > 0)
  286   1          {
  287   2              pkey->click_timer--;
  288   2              
  289   2              // 定时器超时（300ms内没有第二次点击）
  290   2              if (pkey->click_timer == 0)
  291   2              {
  292   3                  // 超时后只需清除单击计数
  293   3                  // 不再重新设置 event = KEY_SINGLE_CLICK！
  294   3                  // 因为第一次释放时已经发送过单击事件并被主循环处理了，
  295   3                  // 如果这里再设一次会导致单击跳两次。
  296   3                  pkey->click_count = 0;
  297   3              }
  298   2          }
  299   1      }
