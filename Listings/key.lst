  203          /*=============================================================================
  204           * 单个按键状态机处理
  205           * 
  206           * 状态转移：
  207           *   0(释放) -> 1(按下) -> 判定为单击?(有),再判双击?(有) -> 0(释放)
  208           *                      -> 长按判定?(有)长按 -> 0(释放)
  209           *
  210           * 双击逻辑：
  211           *   第一次单击后，在300ms内再按一次即为双击
  212           *===========================================================================*/
  213          static void Key_ScanSingle(KEY_Struct *pkey, unsigned char pin)
  214          {
  215   1          pkey->pin_level = pin;
  216   1          
  217   1          // ========== 按键按下过程 ==========
  218   1          if (pkey->pin_level == 0)  // GPIO为0
  219   1          {
  220   2              if (pkey->state == 0)  // 从释放状态进入
  221   2              {
  222   3                  pkey->debounce_cnt++;
  223   3                  if (pkey->debounce_cnt >= KEY_DEBOUNCE_TIME)
  224   3                  {
  225   4                      pkey->state = 1;
  226   4                      pkey->press_time = 0;
  227   4                      pkey->debounce_cnt = 0;
  228   4                  }
  229   3              }
  230   2              else if (pkey->state == 1)
  231   2              {
  232   3                  pkey->press_time++;
  233   3                  
  234   3                  // 长按判定（1000ms）
  235   3                  if (pkey->press_time == KEY_LONG_PRESS_TIME)
  236   3                  {
  237   4                      pkey->event = KEY_LONG_PRESS;
  238   4                      pkey->click_count = 0;  // 清除单击计数，禁止后续双击识别
  239   4                      pkey->click_timer = 0;  // 停止双击定时器
  240   4                  }
  241   3                  // 长按持续中（每100ms）
  242   3                  else if (pkey->press_time > KEY_LONG_PRESS_TIME && 
  243   3                           pkey->press_time % 100 == 0)
  244   3                  {
  245   4                      pkey->event = KEY_PRESSING;
  246   4                  }
  247   3              }
  248   2          }
  249   1          
  250   1          // ========== 按键释放过程 ==========
  251   1          else  // GPIO为1（释放）
  252   1          {
  253   2              if (pkey->state == 1)
  254   2              {
  255   3                  pkey->debounce_cnt++;
  256   3                  if (pkey->debounce_cnt >= KEY_DEBOUNCE_TIME)
C251 COMPILER V5.60.0,  key                                                                19/03/26  17:47:26  PAGE 5   

  257   3                  {
  258   4                      pkey->state = 0;
  259   4                      pkey->debounce_cnt = 0;
