   68          void Buzzer_Update(void)
   69          {
   70   1          unsigned int elapsed_ms;
   71   1          
   72   1          /* 空闲状态，不做任何事 */
   73   1          if (g_buzzer.state == BUZZER_IDLE)
   74   1              return;
   75   1          
   76   1          /* 计算当前段已经过的时间 */
   77   1          elapsed_ms = ms_tick - g_buzzer.start_ms;
   78   1          
   79   1          /* 当前段时间已到，切换到下一段 */
   80   1          if (elapsed_ms >= g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].duration_ms)
   81   1          {
   82   2              g_buzzer.seg_index++;
   83   2              g_buzzer.start_ms = ms_tick;  /* 重置本段开始时间 */
   84   2              
   85   2              /* 检查是否到达最后一段（结束标记 duration_ms=0） */
   86   2              if (g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].duration_ms == 0)
   87   2              {
   88   3                  BUZZER = 0;              /* 确保蜂鸣器关闭 */
   89   3                  g_buzzer.state = BUZZER_IDLE;
   90   3                  g_buzzer.tone_type = TONE_NONE;
   91   3                  return;
   92   3              }
   93   2              
   94   2              /* 设置新段的输出状态 */
   95   2              if (g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].is_on)
   96   2                  BUZZER = 1;  /* 开启 */
   97   2              else
   98   2                  BUZZER = 0;  /* 关闭 */
   99   2          }
  100   1      }
