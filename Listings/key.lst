   88          void Buzzer_Update(void)
   89          {
   90   1          unsigned int elapsed_ms;
   91   1          
   92   1          /* 空闲状态，不做任何事 */
   93   1          if (g_buzzer.state == BUZZER_IDLE)
   94   1              return;
   95   1          
   96   1          /* 计算当前段已经过的时间 */
   97   1          elapsed_ms = ms_tick - g_buzzer.start_ms;
   98   1          
   99   1          /* 当前段时间已到，切换到下一段 */
  100   1          if (elapsed_ms >= g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].duration_ms)
  101   1          {
  102   2              g_buzzer.seg_index++;
  103   2              g_buzzer.start_ms = ms_tick;  /* 重置本段开始时间 */
  104   2              
  105   2              /* 检查是否到达最后一段（结束标记 duration_ms=0） */
  106   2              if (g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].duration_ms == 0)
  107   2              {
  108   3                  BUZZER = 0;              /* 确保蜂鸣器关闭 */
  109   3                  g_buzzer.state = BUZZER_IDLE;
  110   3                  g_buzzer.tone_type = TONE_NONE;
  111   3                  return;
  112   3              }
  113   2              
  114   2              /* 设置新段的输出状态 */
  115   2              if (g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].is_on)
  116   2                  BUZZER = 1;  /* 开启 */
  117   2              else
  118   2                  BUZZER = 0;  /* 关闭 */
  119   2          }
  120   1      }
