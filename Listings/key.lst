  100          void Buzzer_Update(void)
  101          {
  102   1          unsigned int elapsed_ms;
  103   1          
  104   1          /* 空闲状态，不做任何事 */
  105   1          if (g_buzzer.state == BUZZER_IDLE)
  106   1              return;
  107   1          
  108   1          /* 计算当前段已经过的时间 */
  109   1          elapsed_ms = ms_tick - g_buzzer.start_ms;
  110   1          
  111   1          /* 当前段时间已到，切换到下一段 */
  112   1          if (elapsed_ms >= g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].duration_ms)
  113   1          {
  114   2              g_buzzer.seg_index++;
  115   2              g_buzzer.start_ms = ms_tick;  /* 重置本段开始时间 */
  116   2              
  117   2              /* 检查是否到达最后一段（结束标记 duration_ms=0） */
  118   2              if (g_tone_segments[g_buzzer.tone_type][g_buzzer.seg_index].duration_ms == 0)
  119   2              {
  120   3                  BUZZER = 0;              /* 确保蜂鸣器关闭 */
  121   3                  g_buzzer.state = BUZZER_IDLE;
  122   3                  g_buzzer.tone_type = TONE_NONE;
  123   3                  return;
  124   3              }
