  421   2      
  422   2              case ADJ_KI:
  423   2                  sv = (int)g_pid_speed.Ki + step;
  424   2                  if (sv > KI_MAX) sv = KI_MAX;
  425   2                  if (sv < KI_MIN) sv = KI_MIN;
  426   2                  g_pid_speed.Ki   = (int)sv;
