    1          /*==============================================================================
    2           * pid.c  —  位置式PID控制器实现
    3           *
    4           * Kp/Ki/Kd 放大100倍整数存储，计算时再除以100，避免浮点运算。
    5           * 例如：Kp=2.0 → 传入 200
    6           *       Ki=0.20 → 传入 20
    7           *       Kd=0.10 → 传入 10
    8           *==============================================================================*/
    9          
   10          #include "pid.h"
   11          
   12          /*=============================================================================
   13           * PID_Init  —  初始化PID参数
   14           * kp/ki/kd : 实际系数×100的整数值
   15           * out_max/min : 输出限幅
   16           * dead_band   : 死区，误差绝对值小于等于此值时输出为0
   17           *===========================================================================*/
   18          void PID_Init(PID_t *pid,
   19                        int kp, int ki, int kd,
   20                        long out_max, long out_min,
   21                        int dead_band)
   22          {
   23   1          pid->Kp        = kp;
   24   1          pid->Ki        = ki;
   25   1          pid->Kd        = kd;
   26   1          pid->out_max   = out_max;
   27   1          pid->out_min   = out_min;
   28   1          pid->dead_band = dead_band;
   29   1          pid->ki_scale  = 100;   /* 默认×100；角度环在PID_Init后单独设为10000 */
   30   1          PID_Reset(pid);
   31   1      }
   32          
   33          /*=============================================================================
   34           * PID_Reset  —  清零历史状态（切换模式/停机时调用）
   35           *===========================================================================*/
   36          void PID_Reset(PID_t *pid)
   37          {
   38   1          pid->e_prev   = 0;
   39   1          pid->integral = 0;
   40   1          pid->output   = 0;
   41   1      }
   42          
   43          /*=============================================================================
   44           * PID_Calc  —  位置式PID计算，每个控制周期调用一次
   45           *
   46           * 参数：
   47           *   setpoint : 目标值
   48           *   feedback : 反馈值（实际值）
   49           *
   50           * 返回：
   51           *   本次输出值（已限幅）
   52           *
   53           * 计算过程（Kp/Ki/Kd均已×100存储，最后÷100还原）：
   54           *   u = (Kp*e + Ki*integral + Kd*(e - e_prev)) / 100
   55           *
   56           * 抗积分饱和：
   57           *   当 Ki>0 时，将 integral 限幅在 ±(out_max*100/Ki)，
   58           *   使积分项贡献不超过输出限幅，防止积分过大导致超调。
C251 COMPILER V5.60.0,  pid                                                                20/03/26  13:45:01  PAGE 2   

   59           *===========================================================================*/
   60          long PID_Calc(PID_t *pid, int setpoint, int feedback)
   61          {
   62   1          int  err;
   63   1          int  derivative;
   64   1          long output;
   65   1      
   66   1          /* 计算误差 */
   67   1          err = setpoint - feedback;
   68   1      
   69   1          /* 死区处理：误差在死区内时视为0 */
   70   1          if (err <= pid->dead_band && err >= -pid->dead_band)
   71   1              err = 0;
   72   1      
   73   1          /* 积分累加 */
   74   1          pid->integral += (long)err;
   75   1      
   76   1          /* 抗积分饱和：Ki*integral/ki_scale <= out_max → integral <= out_max*ki_scale/Ki */
   77   1          if (pid->Ki > 0)
   78   1          {
   79   2              long ilimit = pid->out_max * (long)pid->ki_scale / (long)pid->Ki;
   80   2              if (pid->integral >  ilimit) pid->integral =  ilimit;
   81   2              if (pid->integral < -ilimit) pid->integral = -ilimit;
   82   2          }
   83   1      
   84   1          /* 微分项（基于误差变化率） */
   85   1          derivative = err - pid->e_prev;
   86   1          pid->e_prev = err;
   87   1      
   88   1          /* 位置式PID输出：Kp/Kd ÷100，Ki ÷ki_scale（各自独立缩放） */
   89   1          output = (long)pid->Kp * (long)err / 100L
   90   1                 + (long)pid->Ki * pid->integral / (long)pid->ki_scale
   91   1                 + (long)pid->Kd * (long)derivative / 100L;
   92   1      
   93   1          /* 输出限幅 */
   94   1          if (output > pid->out_max) output = pid->out_max;
   95   1          if (output < pid->out_min) output = pid->out_min;
   96   1      
   97   1          pid->output = output;
   98   1          return output;
   99   1      }


