stmt  level    source

    1          /*==============================================================================
    2           * pid.c  —  增量式PID控制器实现
    3           *
    4           * Kp/Ki/Kd 放大100倍整数存储，计算时再除以100，避免浮点运算。
    5           * 例如：Kp=1.5 → 传入 150
    6           *       Ki=0.05 → 传入 5
    7           *       Kd=0.02 → 传入 2
    8           *==============================================================================*/
    9          
   10          #include "pid.h"
   11          
   12          /*=============================================================================
   13           * PID_Init  —  初始化PID参数
   14           * kp/ki/kd : 实际系数×100的整数值
   15           * out_max/min : 输出限幅
   16           * dead_band   : 死区，误差绝对值小于此值时输出不变
   17           *===========================================================================*/
   18          void PID_Init(PID_t *pid,
   19                        int kp, int ki, int kd,
   20                        long out_max, long out_min,
   21                        int dead_band)
   22          {
   23   1          pid->Kp       = kp;
   24   1          pid->Ki       = ki;
   25   1          pid->Kd       = kd;
   26   1          pid->out_max  = out_max;
   27   1          pid->out_min  = out_min;
   28   1          pid->dead_band = dead_band;
   29   1          PID_Reset(pid);
   30   1      }
   31          
   32          /*=============================================================================
   33           * PID_Reset  —  清零历史状态（切换模式/停机时调用）
   34           *===========================================================================*/
   35          void PID_Reset(PID_t *pid)
   36          {
   37   1          pid->e0     = 0;
   38   1          pid->e1     = 0;
   39   1          pid->e2     = 0;
   40   1          pid->output = 0;
   41   1      }
   42          
   43          /*=============================================================================
   44           * PID_Calc  —  增量式PID计算，每个控制周期调用一次
   45           *
   46           * 参数：
   47           *   setpoint : 目标值
   48           *   feedback : 反馈值（实际值）
   49           *
   50           * 返回：
   51           *   本次累计输出值（已限幅）
   52           *
   53           * 计算过程（Kp/Ki/Kd均已×100存储，最后÷100还原）：
   54           *   delta_u = Kp*(e0-e1) + Ki*e0 + Kd*(e0-2*e1+e2)
   55           *   u += delta_u / 100
   56           *===========================================================================*/
   57          long PID_Calc(PID_t *pid, int setpoint, int feedback)
   58          {
C251 COMPILER V5.60.0,  pid                                                                15/03/26  15:25:55  PAGE 2   

   59   1          long delta_u;
   60   1          int  err;
   61   1      
   62   1          /* 计算误差 */
   63   1          err = setpoint - feedback;
   64   1      
   65   1          /* 死区处理：误差在死区内，保持输出不变 */
   66   1          if (err < 0) err = -err > pid->dead_band ? setpoint - feedback : 0;
   67   1          else         err =  err > pid->dead_band ? setpoint - feedback : 0;
   68   1      
   69   1          /* 移位历史误差 */
   70   1          pid->e2 = pid->e1;
   71   1          pid->e1 = pid->e0;
   72   1          pid->e0 = err;
   73   1      
   74   1          /*
   75   1           * 增量计算（Kp/Ki/Kd均×100存储，整体再÷100）
   76   1           * 用 long 防止中间溢出
   77   1           */
   78   1          delta_u = (long)pid->Kp * (pid->e0 - pid->e1)
   79   1                  + (long)pid->Ki *  pid->e0
   80   1                  + (long)pid->Kd * (pid->e0 - 2 * pid->e1 + pid->e2);
   81   1          delta_u /= 100;
   82   1      
   83   1          /* 累加到输出 */
   84   1          pid->output += delta_u;
   85   1      
   86   1          /* 输出限幅 */
   87   1          if (pid->output > pid->out_max) pid->output = pid->out_max;
   88   1          if (pid->output < pid->out_min) pid->output = pid->out_min;
   89   1      
   90   1          return pid->output;
   91   1      }


