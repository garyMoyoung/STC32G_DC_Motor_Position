    1          /*==============================================================================
    2           * spi.c  —  SPI 驱动（DMA 模式）
    3           *
    4           * 中断机制说明：
    5           *   SPI DMA 真实中断号 = 49，向量地址 = 018BH
    6           *   Keil C251 只支持 0~31，借用保留中断号 13（向量 006BH）
    7           *   需要 isr.asm 在 018BH 处写一条 LJMP 006BH 做向量跳转
    8           *   spi.c 中用 interrupt 13 定义中断函数（放在 006BH）
    9           *============================================================================*/
   10          
   11          #include "spi.h"
   12          #include <STC32G.H>
   13          #include <intrins.h>
   14          
   15          /*=============================================================================
   16           * DMA 全局变量
   17           *===========================================================================*/
   18          #if (SPI_DMA_CFG == 1)
               bit           SpiDmaFlag;
               unsigned char xdata SpiDmaTxBuffer[SPI_DMA_BUF_SIZE];
               #endif
   22          
   23          /*=============================================================================
   24           * SPI 初始化
   25           *===========================================================================*/
   26          void SPI_Init(void)
   27          {
   28   1          /* SPI 基础配置 */
   29   1          P_SW1 = (P_SW1 & ~(3<<2)) | (1<<2);
   30   1          SSIG  = 1;
   31   1          SPEN  = 1;
   32   1          DORD  = 0;
   33   1          MSTR  = 1;
   34   1          CPOL  = 0;
   35   1          CPHA  = 0;
   36   1          SPCTL = (SPCTL & ~3) | 3;
   37   1          SPI_SCK  = 0;
   38   1          SPI_MOSI = 1;
   39   1          SPIF = 1;
   40   1          WCOL = 1;
   41   1      
   42   1      #if (SPI_DMA_CFG == 1)
                   P_SW2 |= 0x80;              // 打开扩展SFR
               
                   DMA_SPI_STA  = 0x00;        // 清状态
                   DMA_SPI_CFG  = 0xE0;        // SPIIE=1(中断使能), ACT_TX=1, ACT_RX=1
                   DMA_SPI_AMT  = 0x00;
               
                   /* 固定发送缓冲区地址，只设一次 */
                   DMA_SPI_TXAH = (unsigned char)((unsigned int)SpiDmaTxBuffer >> 8);
                   DMA_SPI_TXAL = (unsigned char)((unsigned int)SpiDmaTxBuffer & 0xFF);
               
                   DMA_SPI_CFG2 = 0x00;
                   DMA_SPI_CR   = 0x81;        // ENSPI=1, CLRFIFO=1（不触发）
               
                   P_SW2 &= ~0x80;
               
                   SpiDmaFlag = 0;
C251 COMPILER V5.60.0,  spi                                                                15/03/26  13:22:10  PAGE 2   

               
                   EA = 1;                     // 确保全局中断开启
               #endif
   62   1      }
   63          
   64          /*=============================================================================
   65           * 单字节阻塞发送
   66           *===========================================================================*/
   67          void SPI_WriteByte(unsigned char dat)
   68          {
   69   1          SPDAT = dat;
   70   1          while (SPIF == 0);      // 等移位完成（SPIF置位时SCK可能还在最后半周期）
   71   1          SPIF = 1;
   72   1          WCOL = 1;
   73   1          while (SPI_SCK);        // 等SCK回到空闲低电平，确保最后一位彻底移出
   74   1      }
   75          
   76          /*=============================================================================
   77           * 多字节发送
   78           *===========================================================================*/
   79          void SPI_Transmit(unsigned char *buf, unsigned int len)
   80          {
   81   1      #if (SPI_DMA_CFG == 1)
                   if (len == 0) return;
                   while (SpiDmaFlag);
               
                   SpiDmaFlag = 1;
               
                   P_SW2 |= 0x80;
                   /* 每次发送直接用原始缓冲区地址，不拷贝，避免地址错误 */
                   DMA_SPI_TXAH = (unsigned char)((unsigned int)buf >> 8);
                   DMA_SPI_TXAL = (unsigned char)((unsigned int)buf & 0xFF);
                   DMA_SPI_AMT  = (unsigned char)(len - 1);
                   DMA_SPI_CR  |= 0x40;
                   P_SW2 &= ~0x80;
               #else
   95   1          unsigned int i;
   96   1          for (i = 0; i < len; i++)
   97   1          {
   98   2              SPDAT = buf[i];
   99   2              while (SPIF == 0);
  100   2              SPIF = 1;
  101   2              WCOL = 1;
  102   2          }
  103   1      #endif
  104   1      }
  105          
  106          /*=============================================================================
  107           * 等待DMA完成
  108           *===========================================================================*/
  109          void SPI_DMA_Wait(void)
  110          {
  111   1      #if (SPI_DMA_CFG == 1)
                   while (SpiDmaFlag);
               #endif
  114   1      }
  115          
  116          /*=============================================================================
  117           * SPI DMA 中断服务函数
  118           *
  119           * 使用 interrupt 13（向量006BH，保留中断）
  120           * 配合 isr.asm：在018BH处 LJMP 006BH，将硬件中断导向此函数
  121           *===========================================================================*/
  122          #if (SPI_DMA_CFG == 1)
               void SPI_DMA_ISR(void) interrupt 13
               {
C251 COMPILER V5.60.0,  spi                                                                15/03/26  13:22:10  PAGE 3   

                   P_SW2 |= 0x80;
                   DMA_SPI_STA = 0x00;         // 清中断标志
                   P_SW2 &= ~0x80;
               
                   SpiDmaFlag = 0;             // 通知上层完成
               }
               #endif


