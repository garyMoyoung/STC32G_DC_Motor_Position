   59          void SPI_WriteByte(unsigned char out)
   60          {
   61   1          SPDAT = out;
   62   1          while(SPIF == 0);
   63   1          SPIF = 1;                           //清SPIF标志
   64   1          WCOL = 1;                           //清WCOL标志
