   35          
   36          
   37          void SPI_Init(void)
   38          {
   39   1              P_SW1 = (P_SW1 & ~0x0c) | 0x04;         //SPI: SS(P2.2), MOSI(P2.3), MISO(P2.4), SCLK(P2.5)
   40   1          SSIG = 1;                           //忽略 SS 引脚功能，使用 MSTR 确定器件是主机还是从机
   41   1          SPEN = 1;                           //使能 SPI 功能
   42   1          DORD = 0;                           //先发送/接收数据的高位（MSB）
   43   1          MSTR = 1;                           //设置主机模式
   44   1          CPOL = 0;                           //SCLK 空闲时为低电平，SCLK 的前时钟沿为上升沿，后时钟沿为下降沿
   45   1          CPHA = 0;                           //数据 SS 管脚为低电平驱动第一位数据并在 SCLK 的后时钟沿改变数据
   46   1          SPCTL = (SPCTL & ~3) | 3;           //SPI 时钟频率选择, 0: 4T, 1: 8T,  2: 16T,  3: 2T
   47   1          SPI_SCK = 0;                        //初始化 SPI 信号线
   48   1          SPI_MOSI = 1;                       //初始化 SPI 信号线
   49   1          SPIF = 1;                           //清SPIF标志
   50   1          WCOL = 1;                           //清WCOL标志
   51   1      }
