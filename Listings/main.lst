   90          /*=============================================================================
   91           * Modbus_SyncRegs
   92           * 主循环每轮调用一次：
   93           *   - 把最新运行状态刷新到只读寄存器
   94           *   - 把上位机写入的可写寄存器取回到控制变量
   95           *===========================================================================*/
   96          static void Modbus_SyncRegs(void)
   97          {
   98   1          unsigned char k;
   99   1      
  100   1          /* ── 只读寄存器：用最新状态覆盖 ── */
  101   1          modbus_regs[0] = (unsigned int)g_motor_angle;          /* Motor_Angle  */
  102   1          modbus_regs[1] = (unsigned int)g_motor_speed;          /* Motor_Speed  */
  103   1          modbus_regs[2] = (unsigned int)(g_enc_total >> 16);    /* Encoder_H    */
  104   1          modbus_regs[3] = (unsigned int)(g_enc_total & 0xFFFF); /* Encoder_L    */
  105   1          modbus_regs[7] = g_status_flags;                       /* Status_Flags */
  106   1          modbus_regs[9] = ms_tick;                              /* ms_Tick      */
  107   1      
  108   1          /* 预留寄存器始终为0 */
  109   1          for (k = 10; k < 16; k++)
  110   1              modbus_regs[k] = 0x0000;
  111   1      
  112   1          /* ── 可写寄存器：取回上位机设定值 ── */
  113   1          g_set_speed = (int)modbus_regs[4];       /* Set_Speed    */
  114   1          g_set_angle = (int)modbus_regs[5];       /* Set_Angle    */
  115   1          g_ctrl_mode = (unsigned char)modbus_regs[6]; /* Control_Mode */
  116   1      
  117   1          /* 线圈 Alarm_Clear（bit3）：写1后自动归0，同时清故障标志 */
  118   1          if (modbus_coils & (1 << 3))
  119   1          {
  120   2              g_status_flags = 0;
  121   2              modbus_coils  &= ~(1 << 3);
  122   2          }
  123   1      }
