   38          /*=============================================================================
   39           * 编码器参数（根据硬件确定，修改此处即可）
   40           *
   41           *   ENC_LINES      编码器物理线数        = 11
   42           *   ENC_MULT       AB两相四倍频          = 4
   43           *   GEAR_RATIO     减速比（输出轴：电机） = 60
   44           *   ENC_PPR_MOTOR  电机轴每转脉冲数      = 11 × 4 = 44
   45           *   ENC_PPR_OUTPUT 输出轴每转脉冲数      = 44 × 60 = 2640
   46           *
   47           * 速度公式（采样周期 10ms）：
   48           *   speed(rpm) = enc_delta / ENC_PPR_OUTPUT / 0.01s * 60
   49           *              = enc_delta * 6000 / 2640
   50           *              = enc_delta * 25 / 11        （整数化，避免浮点）
   51           *
   52           * 角度公式（输出轴，0.1° 精度）：
   53           *   angle(0.1°) = (enc_total % ENC_PPR_OUTPUT) * 3600 / ENC_PPR_OUTPUT
   54           *===========================================================================*/
   55          #define ENC_LINES           11
   56          #define ENC_MULT            4
   57          #define GEAR_RATIO          60
   58          #define ENC_PPR_MOTOR       (ENC_LINES * ENC_MULT)          /* 44  脉冲/电机转 */
C251 COMPILER V5.60.0,  main                                                               15/03/26  14:26:01  PAGE 2   

   59          #define ENC_PPR_OUTPUT      (ENC_PPR_MOTOR * GEAR_RATIO)    /* 2640 脉冲/输出轴转 */
