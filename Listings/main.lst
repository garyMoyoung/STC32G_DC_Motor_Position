    1          /*==============================================================================
    2           * main.c  —  集成 Modbus RTU 协议寄存器映射
    3           *
    4           * 寄存器映射（对应通信协议 v1.0）：
    5           *   0x0000  Motor_Angle       电机当前角度（只读，0.1°，带符号）
    6           *   0x0001  Motor_Speed       电机当前转速（只读，rpm，带符号）
    7           *   0x0002  Encoder_Count_H   编码器累计值高16位（只读）
    8           *   0x0003  Encoder_Count_L   编码器累计值低16位（只读）
    9           *   0x0004  Set_Speed         目标转速设定（可读写，rpm）
   10           *   0x0005  Set_Angle         目标角度设定（可读写，0.1°）
   11           *   0x0006  Control_Mode      控制模式（0=速度 1=角度 2=手动）
   12           *   0x0007  Status_Flags      状态标志位（只读）
   13           *   0x0008  PWM_Duty_Raw      原始PWM占空比（手动模式可写）
   14           *   0x0009  ms_Tick           系统时基计数（只读）
   15           *   0x000A~0x000F  预留，读取恒为0
   16           *
   17           * 线圈映射：
   18           *   0x0000  Motor_Enable      电机使能（1=使能，0=禁用）
   19           *   0x0001  Motor_Dir         旋转方向（1=正转，0=反转）
   20           *   0x0002  Brake             制动（1=制动，0=释放）
   21           *   0x0003  Alarm_Clear       故障清除（写1触发，自动归0）
   22           *   0x0004  LED_Status        状态指示灯
   23           *============================================================================*/
