   27          void PWM_Init(void)
   28          {
   29   1          P_SW2 |= 0x80;              // 使能扩展SFR
   30   1      
   31   1          // P1.0 PWM1P，P1.1 PWM1N 推挽输出        ← 改 P2→P1
   32   1          P1M0 |=  0x03;
   33   1          P1M1 &= ~0x03;
   34   1      
   35   1          // 引脚切换：PWMA CH1 默认 P1.0(PWM1P) / P1.1(PWM1N)
   36   1          // C1PS[1:0]=00 → 默认引脚，直接清零低4位    ← 改为 0x00
   37   1          PWMA_PS &= ~0x0F;
   38   1          // PWMA_PS |= 0x00;  // 默认值，无需赋值
   39   1      
   40   1          // ---- PWMA 主控寄存器 ----
   41   1      
   42   1          // PWMx_CR1：控制寄存器1
   43   1          // CMS[1:0]=00：边沿对齐模式
   44   1          // DIR=0：向上计数（0→ARR）
   45   1          // ARPE=1：ARR预装载使能
   46   1          PWMA_CR1 = 0x80;            // CMS=00:边沿对齐，DIR=0，ARPE=1
   47   1      
   48   1          // PWMx_CR2：控制寄存器2
   49   1          // MMS=000：复位，触发输出为复位信号（电机控制一般设此）
   50   1          PWMA_CR2 = 0x00;
   51   1      
   52   1          // 设置预分频：PSC=0 即不分频，计数时钟 = SYSCLK = 33.1776MHz
   53   1          PWMA_PSCRH = 0x00;
   54   1          PWMA_PSCRL = 0x00;
   55   1      
   56   1          // ARR = PWM_ARR = 3317（见 main.h，边沿对齐10kHz）
   57   1          // 实际PWM频率 = FOSC / ARR = 33177600 / 3317 = 10kHz
   58   1          PWMA_ARRH = (PWM_ARR) >> 8;
C251 COMPILER V5.60.0,  timer                                                              19/03/26  15:36:42  PAGE 2   

   59   1          PWMA_ARRL = (PWM_ARR) & 0xFF;
   60   1      
   61   1          // ---- 捕获/比较通道1 配置（互补PWM输出）----
   62   1      
   63   1          // CCMR1：捕获比较模式寄存器1
   64   1          // OC1M[2:0]=110：PWM模式1（计数值<CCR时输出有效电平）
   65   1          // OC1PE=1：CCR1预装载使能
   66   1          PWMA_CCMR1 = 0x68;         // OC1M=110, OC1PE=1
   67   1      
   68   1          // 初始占空比50%（PWM_MID = 停车中点）
   69   1          PWMA_CCR1H = PWM_MID >> 8;
   70   1          PWMA_CCR1L = PWM_MID & 0xFF;
   71   1      
   72   1          // CCER1：捕获比较使能寄存器
   73   1          // CC1E=1：通道1正向输出使能（PWM1P）
   74   1          // CC1P=0：正向输出高电平有效
   75   1          // CC1NE=1：通道1互补输出使能（PWM1N）
   76   1          // CC1NP=0：互补输出高电平有效
   77   1          PWMA_CCER1 = 0x05;         // CC1E=1, CC1NE=1
   78   1      
   79   1          // ---- 死区配置 ----
   80   1          // BKR：刹车寄存器
   81   1          // MOE=1：主输出使能（必须置1，否则PWM无输出！）
   82   1          // OSSR=1：运行模式下关闭状态选择
   83   1          // OSSI=1：空闲模式下关闭状态选择
   84   1          PWMA_BKR = 0xC0;           // MOE=1, OSSR=0, OSSI=0, 无刹车
   85   1      
   86   1          // DTR：死区时间寄存器
   87   1          // DTG[7:0]=60：死区时间 = 60 × Tdts，Tdts=1/SYSCLK≈30ns
   88   1          // 死区 ≈ 60 × 30ns = 1.8us（满足大多数MOS驱动芯片需求）
   89   1          PWMA_DTR = PWM_DEAD_TIME;
   90   1      
   91   1          // 空闲状态输出：OISR
   92   1          // OIS1=0：通道1空闲时输出低
   93   1          // OIS1N=0：互补通道空闲时输出低
   94   1          PWMA_OISR = 0x00;
   95   1      
   96   1          // ---- 使能PWMA计数器 ----
   97   1          // CR1.CEN=1：启动计数器
   98   1          PWMA_CR1 |= 0x01;
   99   1      
  100   1          // 使能通道1和互补通道1输出
  101   1          PWMA_ENO = 0x03;           // ENO1P=1, ENO1N=1
  102   1      
  103   1          P_SW2 &= ~0x80;
  104   1      }
