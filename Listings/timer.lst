  187          int Encoder_Read(void)
  188          {
  189   1          int cnt;
  190   1          unsigned int raw;
C251 COMPILER V5.60.0,  timer                                                              19/03/26  15:36:42  PAGE 4   

  191   1          
  192   1          P_SW2 |= 0x80;
  193   1          raw  = (unsigned int)PWMB_CNTRH << 8;
  194   1          raw |= PWMB_CNTRL;
  195   1          P_SW2 &= ~0x80;
  196   1          
  197   1          // 转换为有符号16位整数
  198   1          // 如果最高位为1，则为负数
  199   1          if (raw & 0x8000) {
  200   2              cnt = -(int)(0x10000 - raw);  // 补码转换
  201   2          } else {
  202   2              cnt = (int)raw;
  203   2          }
  204   1          
  205   1          return cnt;
  206   1      }


