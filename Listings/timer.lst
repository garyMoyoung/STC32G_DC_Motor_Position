    4          void Timer0_Init(void)
    5          {
    6   1          // 定时器0模式0：16位自动重载
    7   1          // TMOD低4位控制T0：M1M0=00
    8   1          TMOD &= 0xF0;               // 清T0模式位，M1=0 M0=0
    9   1      
   10   1          // 1T模式：AUXR.7 = T0x12 = 1
   11   1          AUXR |= 0x80;
   12   1      
