   14   1          TH0 = T0_RELOAD >> 8;       // 高字节 = 0x7E
   15   1          TL0 = T0_RELOAD & 0xFF;     // 低字节 = 0x67
   16   1      
   17   1          // 清中断标志，使能T0中断
   18   1          TF0 = 0;
   19   1          ET0 = 1;
