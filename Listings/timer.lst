  110          void PWM_SetDuty(unsigned int duty)
  111          {
  112   1          if (duty > PWM_ARR) duty = PWM_ARR;
  113   1          P_SW2 |= 0x80;
  114   1          PWMA_CCR1H = duty >> 8;
  115   1          PWMA_CCR1L = duty & 0xFF;
  116   1          P_SW2 &= ~0x80;
  117   1      }
