  127   1          P_SW2 |= 0x80;
  128   1      
  129   1          PWMB_ENO    = 0x00;                     // 禁用所有输出
  130   1          PWMB_PS     = 0x00;                     // 引脚映射到默认位置 (P2.0/P2.1)
  131   1          
  132   1          // 预分频设置
  133   1          PWMB_PSCRH  = 0x00;
  134   1          PWMB_PSCRL  = 0x00;
  135   1          
  136   1          // 自动重装载值（16位，支持有符号）
  137   1          PWMB_ARRH   = 0xFF;
  138   1          PWMB_ARRL   = 0xFF;
  139   1      
  140   1          // 计数器初值
  141   1          PWMB_CNTRH  = 0x00;
  142   1          PWMB_CNTRL  = 0x00;
  143   1      
  144   1          // ===== 关键：输入捕获模式配置 =====
  145   1          // CCMR1: IC1F[7:4] = 0011(滤波), CC1S[1:0] = 01(TI1输入)
  146   1          // = 0011_0001 = 0x31
  147   1          PWMB_CCMR1  = 0x31;        // TI1输入，滤波4时钟
  148   1          
  149   1          // CCMR2: IC2F[7:4] = 0011(滤波), CC2S[1:0] = 01(TI2输入)  
  150   1          // = 0011_0001 = 0x31
  151   1          PWMB_CCMR2  = 0x31;        // TI2输入，滤波4时钟
  152   1       
  153   1          // ===== 编码器模式：双边沿计数 =====
  154   1          // SMS[2:0] = 011（编码器模式3：TI1和TI2都计数）
  155   1          PWMB_SMCR   = 0x03;
  156   1       
  157   1          // ===== 极性配置 =====
  158   1          // CC1E=1, CC1P=0, CC2E=1, CC2P=0
  159   1          // 这样可以正确检测方向
  160   1          // CCER1 = 0000_0101 = 0x05
  161   1          // CCER2 = 0000_0101 = 0x05
  162   1          PWMB_CCER1  = 0x05;        // CC1E=1, CC1P=0 (不反相)
  163   1          PWMB_CCER2  = 0x05;        // CC2E=1, CC2P=0 (不反相)
  164   1          
  165   1          // 禁用中断（轮询模式）
  166   1          PWMB_IER    = 0x00;
  167   1          
  168   1          // 启动计数器
  169   1          PWMB_CR1    = 0x81;        // CEN=1, ARPE=1
  170   1      
  171   1          P_SW2 &= ~0x80;
  172   1          EAXFR = 0;
  173   1      }
  174          
  175          int Encoder_Read(void)
  176          {
  177   1          int cnt;
  178   1          unsigned int raw;
  179   1          
  180   1          P_SW2 |= 0x80;
  181   1          raw  = (unsigned int)PWMB_CNTRH << 8;
  182   1          raw |= PWMB_CNTRL;
  183   1          P_SW2 &= ~0x80;
  184   1          
  185   1          // 转换为有符号16位整数
  186   1          // 如果最高位为1，则为负数
  187   1          if (raw & 0x8000) {
  188   2              cnt = -(int)(0x10000 - raw);  // 补码转换
  189   2          } else {
  190   2              cnt = (int)raw;
