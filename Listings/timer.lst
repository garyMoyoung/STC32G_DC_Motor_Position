   26          
   27          void PWM_Init(void)
   28          {
   29   1          P_SW2 |= 0x80;              // 使能扩展SFR
   30   1      
   31   1          // P1.0 PWM1P，P1.1 PWM1N 推挽输出        ← 改 P2→P1
   32   1          P1M0 |=  0x03;
   33   1          P1M1 &= ~0x03;
   34   1      
   35   1          // 引脚切换：PWMA CH1 默认 P1.0(PWM1P) / P1.1(PWM1N)
   36   1          // C1PS[1:0]=00 → 默认引脚，直接清零低4位    ← 改为 0x00
   37   1          PWMA_PS &= ~0x0F;
   38   1          // PWMA_PS |= 0x00;  // 默认值，无需赋值
   39   1      
   40   1          // ---- PWMA 主控寄存器 ----
   41   1      
   42   1          // PWMx_CR1：控制寄存器1
   43   1          // CMS[1:0]=01：中央对齐模式1（上计数时比较匹配产生中断标志）
   44   1          // DIR=0：向上计数
   45   1          // ARPE=1：ARR预装载使能
   46   1          PWMA_CR1 = 0x60;            // CMS=11:中央对齐3，ARPE=1
   47   1      
   48   1          // PWMx_CR2：控制寄存器2
   49   1          // MMS=000：复位，触发输出为复位信号（电机控制一般设此）
   50   1          PWMA_CR2 = 0x00;
   51   1      
   52   1          // 设置预分频：PSC=0 即不分频，计数时钟 = SYSCLK = 33.1776MHz
   53   1          PWMA_PSCRH = 0x00;
   54   1          PWMA_PSCRL = 0x00;
   55   1      
   56   1          // 设置自动重载值 ARR = PWM_ARR = 1658
   57   1          // 中央对齐模式下，实际PWM频率 = SYSCLK / (2 * ARR)
   58   1          // = 33177600 / (2 * 1658) ≈ 10KHz（中央对齐等效20KHz开关频率）
C251 COMPILER V5.60.0,  timer                                                              13/03/26  17:26:53  PAGE 2   

   59   1          // 若要真正20KHz：ARR = 33177600/20000/2 = 829
   60   1          #undef  PWM_ARR
   61   1          #define PWM_ARR   829       // 中央对齐模式下的ARR值
   62   1      
   63   1          PWMA_ARRH = (PWM_ARR) >> 8;
   64   1          PWMA_ARRL = (PWM_ARR) & 0xFF;
   65   1      
   66   1          // ---- 捕获/比较通道1 配置（互补PWM输出）----
   67   1      
   68   1          // CCMR1：捕获比较模式寄存器1
   69   1          // OC1M[2:0]=110：PWM模式1（计数值<CCR时输出有效电平）
   70   1          // OC1PE=1：CCR1预装载使能
   71   1          PWMA_CCMR1 = 0x68;         // OC1M=110, OC1PE=1
   72   1      
   73   1          // 初始占空比50%：CCR1 = ARR/2
   74   1          PWMA_CCR1H = (PWM_ARR / 2) >> 8;
   75   1          PWMA_CCR1L = (PWM_ARR / 2) & 0xFF;
   76   1      
   77   1          // CCER1：捕获比较使能寄存器
   78   1          // CC1E=1：通道1正向输出使能（PWM1P）
   79   1          // CC1P=0：正向输出高电平有效
   80   1          // CC1NE=1：通道1互补输出使能（PWM1N）
   81   1          // CC1NP=0：互补输出高电平有效
   82   1          PWMA_CCER1 = 0x05;         // CC1E=1, CC1NE=1
   83   1      
   84   1          // ---- 死区配置 ----
   85   1          // BKR：刹车寄存器
   86   1          // MOE=1：主输出使能（必须置1，否则PWM无输出！）
   87   1          // OSSR=1：运行模式下关闭状态选择
   88   1          // OSSI=1：空闲模式下关闭状态选择
   89   1          PWMA_BKR = 0xC0;           // MOE=1, OSSR=0, OSSI=0, 无刹车
   90   1      
   91   1          // DTR：死区时间寄存器
   92   1          // DTG[7:0]=60：死区时间 = 60 × Tdts，Tdts=1/SYSCLK≈30ns
   93   1          // 死区 ≈ 60 × 30ns = 1.8us（满足大多数MOS驱动芯片需求）
   94   1          PWMA_DTR = PWM_DEAD_TIME;
   95   1      
   96   1          // 空闲状态输出：OISR
   97   1          // OIS1=0：通道1空闲时输出低
   98   1          // OIS1N=0：互补通道空闲时输出低
   99   1          PWMA_OISR = 0x00;
  100   1      
  101   1          // ---- 使能PWMA计数器 ----
  102   1          // CR1.CEN=1：启动计数器
  103   1          PWMA_CR1 |= 0x01;
  104   1      
  105   1          // 使能通道1和互补通道1输出
  106   1          PWMA_ENO = 0x03;           // ENO1P=1, ENO1N=1
  107   1      
  108   1          P_SW2 &= ~0x80;
  109   1      }
