  135          void PWMB_Encoder_Init(void)
  136          {
  137   1          EAXFR = 1;
  138   1          P_SW2 |= 0x80;
  139   1      
  140   1          PWMB_ENO    = 0x00;                     // 禁用所有输出
  141   1          PWMB_PS     = 0x00;                     // 引脚映射到默认位置 (P2.0/P2.1)
  142   1          
  143   1          // 预分频设置
  144   1          PWMB_PSCRH  = 0x00;
  145   1          PWMB_PSCRL  = 0x00;
  146   1          
  147   1          // 自动重装载值（16位，支持有符号）
  148   1          PWMB_ARRH   = 0xFF;
  149   1          PWMB_ARRL   = 0xFF;
  150   1      
  151   1          // 计数器初值
  152   1          PWMB_CNTRH  = 0x00;
  153   1          PWMB_CNTRL  = 0x00;
  154   1      
  155   1          // ===== 关键：输入捕获模式配置 =====
  156   1          // CCMR1: IC1F[7:4] = 1111(最大滤波 f/32×N=8 ≈7.7us), CC1S[1:0] = 01(TI1输入)
  157   1          // = 1111_0001 = 0xF1
  158   1          // 注：滤波从0x31(0.24us)提升到0xF1(7.7us)，用于抑制10kHz PWM开关噪声干扰
  159   1          PWMB_CCMR1  = 0xF1;        // TI1输入，最大滤波（7.7us），抑制PWM噪声
  160   1      
  161   1          // CCMR2: IC2F[7:4] = 1111, CC2S[1:0] = 01(TI2输入)
  162   1          // = 1111_0001 = 0xF1
  163   1          PWMB_CCMR2  = 0xF1;        // TI2输入，最大滤波（7.7us），抑制PWM噪声
  164   1       
  165   1          // ===== 编码器模式：双边沿计数 =====
  166   1          // SMS[2:0] = 011（编码器模式3：TI1和TI2都计数）
  167   1          PWMB_SMCR   = 0x03;
  168   1       
  169   1          // ===== 极性配置 =====
  170   1          // CC1E=1, CC1P=0, CC2E=1, CC2P=0
  171   1          // 这样可以正确检测方向
  172   1          // CCER1 = 0000_0101 = 0x05
  173   1          // CCER2 = 0000_0101 = 0x05
  174   1          PWMB_CCER1  = 0x05;        // CC1E=1, CC1P=0 (不反相)
  175   1          PWMB_CCER2  = 0x05;        // CC2E=1, CC2P=0 (不反相)
  176   1          
  177   1          // 禁用中断（轮询模式）
  178   1          PWMB_IER    = 0x00;
  179   1          
  180   1          // 启动计数器
  181   1          PWMB_CR1    = 0x81;        // CEN=1, ARPE=1
  182   1      
  183   1          P_SW2 &= ~0x80;
  184   1          EAXFR = 0;
  185   1      }
